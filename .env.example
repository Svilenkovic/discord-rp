# Iz Discord Developer Portal → Bot tab → Token
DISCORD_TOKEN=

# Iz Developer Portal → General Information → Application ID
CLIENT_ID=

# Iz test servera (desni klik → Copy ID, mora ti biti uključen Developer Mode u Discord settings)
# Ostavi prazno za globalnu registraciju komandi (do 1h propagacija)
GUILD_ID=

# FiveM server (za /stats i auto-status embed). Format: IP:PORT (npr. 46.225.15.162:30120)
FIVEM_SERVER_IP=

# Anthropic API (za /claude dispatch komandu sa telefona). https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
